# PDF conversion (optional — .docx output always works without this).
# LibreOffice is used automatically if installed and found on PATH.
# Otherwise, set CLOUDCONVERT_API_KEY to use CloudConvert's free tier
# (25 conversions/day) instead — note this uploads your document to
# CloudConvert's servers.
CLOUDCONVERT_API_KEY=

# Force a specific backend instead of auto-detecting: "libreoffice" | "cloudconvert"
PDF_BACKEND=
